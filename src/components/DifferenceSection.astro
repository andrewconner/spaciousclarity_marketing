---
const principles = [
	{
		title: 'Life-affirming, not renunciative',
		copy: 'Welcome emotions, thoughts, and ordinary life, rather than regarding them as obstacles to overcome.',
	},
	{
		title: 'Sustainable Practice',
		copy: 'Build a meditation habit that actually fits into your real, ordinary life, not just for the mountain tops.',
	},
	{
		title: 'Presence in Daily Life',
		copy: "Become more present in your interactions, not just while you're meditating.",
	},
	{
		title: 'Relief from Striving',
		copy: 'Find a radical alternative to exhausting, effort-based self-improvement approaches that leave you drained.',
	},
];
---

<section class="principles-section" id="principles" aria-labelledby="principles-heading">
	<div class="principles-contour" aria-hidden="true">
		<svg viewBox="0 0 600 600" fill="none" focusable="false">
			<path d="M 60 320 C 140 280 240 270 320 282 C 400 294 480 326 560 324" />
			<path d="M 80 280 C 160 240 260 228 340 242 C 420 256 500 290 580 286" />
			<path d="M 110 236 C 190 198 290 188 370 202 C 450 216 520 250 600 244" />
			<path d="M 150 194 C 230 160 320 152 400 166 C 470 178 540 208 610 200" />
			<path d="M 200 160 C 270 132 350 126 420 138 C 480 148 540 172 610 164" />
			<path d="M 250 130 C 310 112 380 108 440 118 C 500 128 560 150 620 142" />
		</svg>
	</div>

	<div class="shell">
		<header class="principles-heading">
			<span class="label label--on-dark">What Makes This Different</span>
			<h2 id="principles-heading">
				Four commitments that shape the <em>whole course.</em>
			</h2>
		</header>

		<ol class="principles-list">
			{
				principles.map((p, i) => (
					<li class="principle">
						<span class="principle-number">{String(i + 1).padStart(2, '0')}</span>
						<div class="principle-body">
							<h3 class="principle-title">{p.title}</h3>
							<p class="principle-copy">{p.copy}</p>
						</div>
					</li>
				))
			}
		</ol>
	</div>
</section>
