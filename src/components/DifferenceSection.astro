---
import FeatureIcon from './FeatureIcon.astro';

const cards = [
	{
		icon: 'spa',
		title: 'Life-affirming, not renunciative',
		copy: 'Welcome emotions, thoughts, and ordinary life, rather than regarding them as obstacles to overcome.',
	},
	{
		icon: 'restore',
		title: 'Sustainable Practice',
		copy: 'Build a meditation habit that actually fits into your real, ordinary life, not just for the mountain tops.',
	},
	{
		icon: 'visibility',
		title: 'Presence in Daily Life',
		copy: "Become more present and vivid during your daily activities, not just while you're meditating.",
	},
	{
		icon: 'all_inclusive',
		title: 'Emotional Resilience',
		copy: 'Handle difficult emotions with spaciousness and curiosity instead of being overwhelmed or rigidly controlling them.',
	},
	{
		icon: 'energy_savings_leaf',
		title: 'Relief from Effort',
		copy: 'Find a radical alternative to exhausting, effort-based self-improvement approaches that leave you drained.',
	},
	{
		icon: 'groups',
		title: 'Improved Relationships',
		copy: 'Discover capacity for authenticity, responsiveness, and rich connections with those around you.',
	},
];
---

<section class="difference-section" id="difference">
	<div class="shell">
		<div class="difference-heading">
			<h2>What makes this different</h2>
		</div>

		<div class="feature-grid">
			{
				cards.map((card) => (
					<article class="feature-card">
						<FeatureIcon name={card.icon} />
						<h3>{card.title}</h3>
						<p>{card.copy}</p>
					</article>
				))
			}
		</div>
	</div>
</section>
