---
import FeatureIcon from './FeatureIcon.astro';

const cards = [
	{
		icon: 'spa',
		title: 'Life-affirming, not renunciative',
		copy: 'Welcomes emotions, thoughts, and ordinary life as part of practice, rather than something to be discarded.',
	},
	{
		icon: 'psychology_alt',
		title: 'Fully adaptive and dynamic course',
		copy: 'The course adapts to your experience, pulling from over 100 lessons to craft a maximally impactful experience.',
	},
	{
		icon: 'restore',
		title: 'Sustainable Practice',
		copy: 'Build a meditation habit that actually fits into your real, ordinary life, not just for the mountain tops.',
	},
	{
		icon: 'visibility',
		title: 'Presence in Daily Life',
		copy: 'Learn to feel more present and vivid during your daily activities, not just during the time on the cushion.',
	},
	{
		icon: 'all_inclusive',
		title: 'Emotional Resilience',
		copy: 'Handle difficult emotions with spaciousness and curiosity instead of being overwhelmed or controlled by them.',
	},
	{
		icon: 'energy_savings_leaf',
		title: 'Relief from Effort',
		copy: 'Find a radical alternative to exhausting, effort-based self-improvement approaches that leave you drained.',
		highlight: true,
	},
	{
		icon: 'groups',
		title: 'Improved Relationships',
		copy: 'Greater presence leads to more authentic, responsive, and deeply felt connections with those around you.',
	},
];
---

<section class="difference-section" id="difference">
	<div class="shell">
		<div class="difference-heading">
			<h2>What makes this different</h2>
			<p>Part Six: Real Involvement</p>
		</div>

		<div class="feature-grid">
			{
				cards.map((card) => (
					<article class:list={['feature-card', card.highlight && 'feature-card--highlight']}>
						<FeatureIcon name={card.icon} highlight={card.highlight} />
						<h3>{card.title}</h3>
						<p>{card.copy}</p>
					</article>
				))
			}

			<div class="texture-card" aria-hidden="true">
				<img src="/images/linen-reference.jpg" alt="" loading="lazy" decoding="async" />
			</div>
		</div>
	</div>
</section>
