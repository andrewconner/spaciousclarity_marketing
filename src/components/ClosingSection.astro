---
import { primaryContactHref, site } from '../content/site';
---

<section class="waitlist-section" id="begin">
	<div class="waitlist-inner">
		<h2>Join the next cohort</h2>
		<p>
			Our guided courses open three times a year. Get notified when enrollment for
			the next session begins.
		</p>

		<div class="waitlist-bar">
			<a class="waitlist-address" href={primaryContactHref}>
				<span>Email address</span>
				<strong>{site.email}</strong>
			</a>
			<a class="button waitlist-button" href={primaryContactHref}>Join</a>
		</div>

		<p class="waitlist-note">Quiet updates only. No noise.</p>
	</div>
</section>
