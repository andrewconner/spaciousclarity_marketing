---
import { site } from '../content/site';
---

<section class="closing-section" id="begin" aria-labelledby="closing-heading">
	<div class="closing-inner">
		<span class="label">Course Access</span>

		<h2 id="closing-heading">
			Get <em>early access</em> to the course.
		</h2>
		<p>
			We're actively building and testing the course, and adding new people on a
			rolling basis. Leave your email and we'll keep you included as we expand
			access.
		</p>

		<form
			class="closing-waitlist"
			data-waitlist
			data-waitlist-recipient={site.email}
			novalidate
		>
			<label class="sr-only" for="closing-email">Email address</label>
			<div class="closing-waitlist-field">
				<input
					id="closing-email"
					class="closing-waitlist-input"
					name="email"
					type="email"
					autocomplete="email"
					inputmode="email"
					placeholder="you@example.com"
					required
				/>
				<button class="closing-waitlist-button" type="submit">Join the waitlist</button>
			</div>
		</form>
	</div>
</section>

