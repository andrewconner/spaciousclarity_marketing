---
import { site } from '../content/site';
---

<section class="hero" aria-labelledby="hero-heading">
	<div class="hero-backdrop" aria-hidden="true">
		<img
			class="hero-image-source"
			src="/images/hero-1800.jpg"
			srcset="/images/hero-800.jpg 800w, /images/hero-1400.jpg 1400w, /images/hero-1800.jpg 1800w"
			sizes="100vw"
			alt=""
			width="1800"
			height="2400"
			loading="eager"
			decoding="async"
			fetchpriority="high"
		/>
		<div class="hero-paper-shader" aria-hidden="true"></div>
		<div class="hero-scrim" aria-hidden="true"></div>
	</div>

	<div class="shell hero-shell">
		<div class="hero-masthead">
			<h1 class="hero-mark">
				<img
					class="hero-mark-logo"
					src="/images/logo.svg"
					alt=""
					width="32"
					height="32"
					decoding="async"
					loading="eager"
				/>
				<span class="hero-mark-text">Spacious Clarity</span>
			</h1>
			<span class="hero-masthead-meta">An Opening Awareness Course</span>
		</div>

		<div class="hero-copy">
			<h2 id="hero-heading" class="hero-title">
				Meditation that welcomes <em>all of life.</em>
			</h2>

			<p class="hero-intro">
				Uncomplicated presence that leads to spacious clarity and vividness with
				life as it actually is
			</p>

			<form
				class="hero-waitlist"
				data-waitlist
				data-waitlist-recipient={site.email}
				novalidate
			>
				<p class="hero-waitlist-note">
					The course opens on a rolling basis. Leave your email for early access.
				</p>
				<div class="hero-waitlist-field">
					<label class="sr-only" for="hero-email">Email address</label>
					<input
						id="hero-email"
						class="hero-waitlist-input"
						name="email"
						type="email"
						autocomplete="email"
						inputmode="email"
						placeholder="you@example.com"
						required
					/>
					<button class="hero-waitlist-button" type="submit">Join the waitlist</button>
				</div>
			</form>
		</div>
	</div>
</section>

<script>
	import {
		ShaderFitOptions,
		ShaderMount,
		getShaderColorFromString,
		getShaderNoiseTexture,
		halftoneCmykFragmentShader,
	} from '@paper-design/shaders';
	import { initWaitlistForms } from '../scripts/waitlist';

	const waitForImage = (image: HTMLImageElement) =>
		image.complete && image.naturalWidth > 0
			? Promise.resolve(image)
			: new Promise<HTMLImageElement>((resolve, reject) => {
					image.addEventListener('load', () => resolve(image), { once: true });
					image.addEventListener(
						'error',
						() => reject(new Error(`Failed to load ${image.src}`)),
						{ once: true },
					);
				});

	const initHeroPaperTexture = async () => {
		const hero = document.querySelector('.hero');
		const image = hero?.querySelector('.hero-image-source');
		const shaderHost = hero?.querySelector('.hero-paper-shader');

		if (
			!(hero instanceof HTMLElement) ||
			!(image instanceof HTMLImageElement) ||
			!(shaderHost instanceof HTMLElement)
		) {
			return;
		}

		if ('paperShaderMount' in shaderHost && shaderHost.paperShaderMount) return;

		try {
			const noiseTexture = getShaderNoiseTexture();
			if (!(noiseTexture instanceof HTMLImageElement)) return;

			await Promise.all([waitForImage(image), waitForImage(noiseTexture)]);

			new ShaderMount(
				shaderHost,
				halftoneCmykFragmentShader,
				{
					u_image: image,
					u_noiseTexture: noiseTexture,
					u_colorBack: getShaderColorFromString('#fbfaf4'),
					u_colorC: getShaderColorFromString('#00b3ff'),
					u_colorM: getShaderColorFromString('#fc4f9d'),
					u_colorY: getShaderColorFromString('#ffd900'),
					u_colorK: getShaderColorFromString('#231f20'),
					u_size: 0.01,
					u_gridNoise: 0.18,
					u_type: 2,
					u_softness: 1,
					u_contrast: 1.09,
					u_floodC: 0.26,
					u_floodM: 0.07,
					u_floodY: 0,
					u_floodK: 0,
					u_gainC: 0.07,
					u_gainM: 0.42,
					u_gainY: 0.51,
					u_gainK: -0.02,
					u_grainMixer: 0.04,
					u_grainOverlay: 0,
					u_grainSize: 0,
					u_fit: ShaderFitOptions.cover,
					u_scale: 1.08,
					u_rotation: 0,
					u_originX: 0.5,
					u_originY: 0,
					u_offsetX: 0,
					u_offsetY: 0,
					u_worldWidth: 0,
					u_worldHeight: 0,
				},
				undefined,
				0,
			);

			hero.classList.add('hero--paper-ready');
		} catch (error) {
			console.error('Paper texture hero shader failed to initialize.', error);
		}
	};

	const run = () => {
		void initHeroPaperTexture();
		initWaitlistForms();
	};

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', run, { once: true });
	} else {
		run();
	}
</script>
