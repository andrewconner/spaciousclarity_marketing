---
import { primaryContactHref } from '../content/site';
---

<section class="hero">
	<div class="shell hero-grid">
		<div class="hero-copy">
			<p class="eyebrow">Grounded Mindfulness</p>
			<h1>Meditation that welcomes all of life.</h1>
			<p class="hero-intro">
				A life-affirming practice that leads to spacious clarity, vivid,
				uncomplicated presence with life as it actually is.
			</p>

			<div class="hero-actions">
				<a class="button" href={primaryContactHref}>Start practicing</a>
				<a class="button button--outline" href="#method">The philosophy</a>
			</div>
		</div>

		<div class="hero-media">
			<div class="hero-image-frame">
				<img
					src="/images/hero-reference.jpg"
					alt="Warm morning sunlight hitting a minimalist wooden floor with a single small potted plant"
					loading="eager"
					decoding="async"
				/>
			</div>

			<aside class="hero-quote">
				<p>"The goal isn't to leave the world, but to inhabit it fully."</p>
			</aside>
		</div>
	</div>
</section>
