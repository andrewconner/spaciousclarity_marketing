---
import HeroCopy from './HeroCopy.astro';
---

<section class="hero" aria-labelledby="hero-heading">
	<div class="hero-backdrop" aria-hidden="true">
		<div class="hero-art">
			<img
				class="hero-image-source"
				src="/images/hero-1800.jpg"
				srcset="/images/hero-800.jpg 800w, /images/hero-1400.jpg 1400w, /images/hero-1800.jpg 1800w"
				sizes="100vw"
				alt=""
				width="1800"
				height="2400"
				loading="eager"
				decoding="async"
				fetchpriority="high"
			/>
			<div class="hero-paper-shader" aria-hidden="true"></div>
		</div>
		<div class="hero-scrim" aria-hidden="true"></div>
	</div>

	<HeroCopy />
</section>

<script>
	import {
		ShaderFitOptions,
		ShaderMount,
		getShaderColorFromString,
		getShaderNoiseTexture,
		halftoneCmykFragmentShader,
	} from '@paper-design/shaders';
	import { initKitAttributionFields } from '../scripts/kit-attribution';

	const waitForImage = (image: HTMLImageElement) =>
		image.complete && image.naturalWidth > 0
			? Promise.resolve(image)
			: new Promise<HTMLImageElement>((resolve, reject) => {
					image.addEventListener('load', () => resolve(image), { once: true });
					image.addEventListener(
						'error',
						() => reject(new Error(`Failed to load ${image.src}`)),
						{ once: true },
					);
				});

	const initHeroShader = async () => {
		const hero = document.querySelector('.hero');
		const image = hero?.querySelector('.hero-image-source');
		const shaderHost = hero?.querySelector('.hero-paper-shader');

		if (
			!(hero instanceof HTMLElement) ||
			!(image instanceof HTMLImageElement) ||
			!(shaderHost instanceof HTMLElement)
		) return;

		try {
			const noiseTexture = getShaderNoiseTexture();
			if (!(noiseTexture instanceof HTMLImageElement)) return;
			await Promise.all([waitForImage(image), waitForImage(noiseTexture)]);

			// Risograph-style two-ink pull: Midnight (K) + Sun Clay (M) on Chalk paper.
			// C and Y channels are tuned to brand-adjacent tones and gained down so the
			// output reads as a screenprint rather than a full CMYK halftone.
			new ShaderMount(
				shaderHost,
				halftoneCmykFragmentShader,
				{
					u_image: image,
					u_noiseTexture: noiseTexture,
					u_colorBack: getShaderColorFromString('#fbf8f2'),
					u_colorC: getShaderColorFromString('#17303a'),
					u_colorM: getShaderColorFromString('#c87435'),
					u_colorY: getShaderColorFromString('#c6a36a'),
					u_colorK: getShaderColorFromString('#10212b'),
					u_size: 0.017,
					u_gridNoise: 0.22,
					u_type: 2,
					u_softness: 0.85,
					u_contrast: 1.18,
					u_floodC: 0.08,
					u_floodM: 0.04,
					u_floodY: 0.02,
					u_floodK: 0,
					u_gainC: 0.35,
					u_gainM: 0.55,
					u_gainY: 0.1,
					u_gainK: 0.04,
					u_grainMixer: 0.06,
					u_grainOverlay: 0,
					u_grainSize: 0,
					u_fit: ShaderFitOptions.cover,
					u_scale: 1,
					u_rotation: 0,
					u_originX: 0,
					u_originY: 0,
					u_offsetX: 0,
					u_offsetY: 0,
					u_worldWidth: 0,
					u_worldHeight: 0,
				},
				undefined,
				0,
			);
		} catch (error) {
			console.error('Hero shader failed to initialize.', error);
		}
	};

	const run = () => {
		initKitAttributionFields();
		void initHeroShader();
	};

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', run, { once: true });
	} else {
		run();
	}
</script>
