---
import { site } from '../content/site';
---

<div class="shell hero-shell">
	<div class="hero-masthead">
		<h1 class="hero-mark">
			<img
				class="hero-mark-logo"
				src="/images/logo.svg"
				alt=""
				width="32"
				height="32"
				decoding="async"
				loading="eager"
			/>
			<span class="hero-mark-text">Spacious Clarity</span>
		</h1>
		<span class="hero-masthead-meta">An Opening Awareness Course</span>
	</div>

	<div class="hero-copy">
		<h2 id="hero-heading" class="hero-title">
			Meditation that welcomes <em>all of life.</em>
		</h2>

		<p class="hero-intro">
			Find uncomplicated presence, leading to spacious clarity and experience of
			vividness with life as it actually is.
		</p>

		<form
			class="hero-waitlist seva-form formkit-form"
			action={site.waitlist.action}
			method="post"
			data-sv-form={site.waitlist.formId}
			data-uid={site.waitlist.uid}
			data-format="inline"
			data-version="5"
			data-options={site.waitlist.options}
		>
			<input type="hidden" name="fields[signup_source]" value={site.waitlist.source} />
			<input type="hidden" name="fields[signup_box]" value="hero" />
			<input type="hidden" name="fields[referrer]" data-kit-attribution="referrer" />
			<input type="hidden" name="fields[utm_source]" data-kit-attribution="utm_source" />
			<input type="hidden" name="fields[utm_medium]" data-kit-attribution="utm_medium" />
			<input type="hidden" name="fields[utm_campaign]" data-kit-attribution="utm_campaign" />
			<input type="hidden" name="fields[utm_term]" data-kit-attribution="utm_term" />
			<input type="hidden" name="fields[utm_content]" data-kit-attribution="utm_content" />
			<p class="hero-waitlist-note">
				The course opens on a rolling basis. Leave your email for early access.
			</p>
			<div class="hero-waitlist-field" data-element="fields">
				<label class="sr-only" for="hero-email">Email address</label>
				<input
					id="hero-email"
					class="hero-waitlist-input"
					name="email_address"
					type="email"
					autocomplete="email"
					inputmode="email"
					placeholder="you@example.com"
					required
				/>
				<button class="hero-waitlist-button" type="submit" data-element="submit">
					Join the waitlist
				</button>
			</div>
		</form>
	</div>
</div>
