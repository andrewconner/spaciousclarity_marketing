---
interface Props {
	name: string;
}

const { name } = Astro.props;
const stroke = 'currentColor';
---

<span class="feature-icon" aria-hidden="true">
	{
		name === 'spa' && (
			<svg viewBox="0 0 24 24" fill="none" stroke={stroke} stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
				<path d="M12 20c3.8 0 6-2.6 6-6.1 0-4.6-4.2-7.9-6-9.8-1.8 1.9-6 5.2-6 9.8C6 17.4 8.2 20 12 20Z" />
				<path d="M12 9.2c1.3 1.3 2.8 2.8 2.8 4.9" />
			</svg>
		)
	}
	{
		name === 'psychology_alt' && (
			<svg viewBox="0 0 24 24" fill="none" stroke={stroke} stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
				<path d="M9 18h6a4 4 0 0 0 4-4V9.5A5.5 5.5 0 0 0 13.5 4H12A7 7 0 0 0 5 11v1a6 6 0 0 0 4 6Z" />
				<path d="M10 9.5c.5-.8 1.2-1.2 2-1.2 1.4 0 2.5 1 2.5 2.3 0 2-2.5 2-2.5 4" />
				<path d="M12 16.8h.1" />
			</svg>
		)
	}
	{
		name === 'restore' && (
			<svg viewBox="0 0 24 24" fill="none" stroke={stroke} stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
				<path d="M4 12a8 8 0 1 0 2.3-5.7" />
				<path d="M4 5v4h4" />
				<path d="M12 8v4l2.5 2.5" />
			</svg>
		)
	}
	{
		name === 'visibility' && (
			<svg viewBox="0 0 24 24" fill="none" stroke={stroke} stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
				<path d="M2.5 12S6 6.5 12 6.5 21.5 12 21.5 12 18 17.5 12 17.5 2.5 12 2.5 12Z" />
				<circle cx="12" cy="12" r="2.8" />
			</svg>
		)
	}
	{
		name === 'all_inclusive' && (
			<svg viewBox="0 0 24 24" fill="none" stroke={stroke} stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
				<path d="M5 15c2.2 0 3.2-1.5 4.4-3.3C10.8 9.7 12 8 14.3 8c2.8 0 4.7 2.7 4.7 5.5S17.1 19 14.3 19c-2.2 0-3.2-1.5-4.4-3.3C8.5 13.7 7.3 12 5 12" />
				<path d="M5 8c1.6 0 2.5.8 3.3 1.8" />
			</svg>
		)
	}
	{
		name === 'energy_savings_leaf' && (
			<svg viewBox="0 0 24 24" fill="none" stroke={stroke} stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
				<path d="M18.5 5.5c-6.6 0-10 3.2-10 8.4 0 3.1 2.1 5.6 5.4 5.6 4.6 0 6.6-4.5 6.6-9.3 0-1.6-.3-3.1-.6-4.7Z" />
				<path d="M7 19c2.5-2.2 5.4-4.6 10.5-7.2" />
			</svg>
		)
	}
	{
		name === 'groups' && (
			<svg viewBox="0 0 24 24" fill="none" stroke={stroke} stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
				<circle cx="9" cy="9" r="2.5" />
				<circle cx="16.5" cy="10" r="2" />
				<path d="M4.5 18c0-2.5 2.4-4.5 5.5-4.5s5.5 2 5.5 4.5" />
				<path d="M14.5 17.5c.3-1.7 1.8-3.1 4-3.4 1.1-.1 2.1.1 3 .6" />
			</svg>
		)
	}
</span>
