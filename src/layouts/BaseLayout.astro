---
import hostGroteskFontUrl from '@fontsource-variable/host-grotesk/files/host-grotesk-latin-wght-normal.woff2?url';
import literataFontUrl from '@fontsource-variable/literata/files/literata-latin-wght-normal.woff2?url';
import { site } from '../content/site';
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
	path?: string;
	image?: string;
	noindex?: boolean;
}

const {
	title = site.title,
	description = site.description,
	path = '/',
	image = '/og-card.svg',
	noindex = false,
} = Astro.props;

const canonical = new URL(path, site.url).toString();
const socialImage = new URL(image, site.url).toString();
const schema = {
	'@context': 'https://schema.org',
	'@type': 'WebSite',
	name: site.name,
	url: site.url,
	description,
};
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<meta name="theme-color" content="#10212b" />
		<meta name="robots" content={noindex ? 'noindex' : 'index,follow'} />
		<link rel="canonical" href={canonical} />
		<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
		<link
			rel="preload"
			href={literataFontUrl}
			as="font"
			type="font/woff2"
			crossorigin="anonymous"
		/>
		<link
			rel="preload"
			href={hostGroteskFontUrl}
			as="font"
			type="font/woff2"
			crossorigin="anonymous"
		/>
		<meta property="og:type" content="website" />
		<meta property="og:site_name" content={site.name} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonical} />
		<meta property="og:image" content={socialImage} />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={socialImage} />
		<title>{title}</title>
		<script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
	</head>
	<body>
		<a class="skip-link" href="#main-content">Skip to content</a>
		<slot />
	</body>
</html>
