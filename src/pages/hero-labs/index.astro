---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteFooter from '../../components/SiteFooter.astro';

const variants = [
	{
		number: '01',
		slug: 'contour-field',
		title: 'Generative contour field',
		summary:
			'No photo. A procedurally-drawn topographic map — closed loops, irregular spacing, index lines every fourth ring. The altitude field drifts slowly. Sun Clay disk parks at a fixed peak.',
	},
	{
		number: '02',
		slug: 'risograph',
		title: 'Risograph duotone',
		summary:
			'Keeps the photograph. Halftone shader retuned into a 2-ink screenprint: Midnight + Sun Clay on Chalk. Visible dots, analog ink feel, bolder brand presence.',
	},
];
---

<BaseLayout
	title="Hero Labs | Spacious Clarity"
	description="Hero texture variants under consideration."
	path="/hero-labs/"
	noindex={true}
>
	<main id="main-content" class="labs-index">
		<div class="shell">
			<span class="label">Hero Labs</span>
			<h1 class="hero-title" style="margin-top: 1.5rem; margin-bottom: 1rem;">
				Two directions for the <em>hero texture.</em>
			</h1>
			<p style="font-family: var(--font-serif); font-size: var(--fs-body-lg); line-height: 1.6; color: var(--ink-soft); max-width: 40rem; margin: 0;">
				Each link opens a full-page preview with that variant's hero. The rest of
				the page — approach, teacher, testimonial, principles, closing — stays
				identical so you can compare texture in context. Current live site remains at <a href="/" style="text-decoration: underline; text-decoration-color: var(--accent); text-underline-offset: 3px;">/</a>.
			</p>

			<div class="labs-index-grid">
				{variants.map((v) => (
					<a class="labs-index-card" href={`/hero-labs/${v.slug}/`}>
						<span class="labs-index-number">No. {v.number}</span>
						<h3>{v.title}</h3>
						<p>{v.summary}</p>
					</a>
				))}
			</div>

			<div class="labs-nav">
				<a href="/">← Back to current site</a>
			</div>
		</div>
	</main>

	<SiteFooter />
</BaseLayout>
