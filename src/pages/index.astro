---
import ApproachSection from '../components/ApproachSection.astro';
import ClosingSection from '../components/ClosingSection.astro';
import DifferenceSection from '../components/DifferenceSection.astro';
import Hero from '../components/Hero.astro';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import { site } from '../content/site';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title={site.title} description={site.description} path="/">
	<SiteHeader />

	<main id="main-content">
		<Hero />
		<ApproachSection />
		<DifferenceSection />
		<ClosingSection />
	</main>

	<SiteFooter />
</BaseLayout>
