---
import ApproachSection from '../components/ApproachSection.astro';
import ClosingSection from '../components/ClosingSection.astro';
import DifferenceSection from '../components/DifferenceSection.astro';
import Hero from '../components/Hero.astro';
import SiteFooter from '../components/SiteFooter.astro';
import TeacherSection from '../components/TeacherSection.astro';
import TestimonialSection from '../components/TestimonialSection.astro';
import { site } from '../content/site';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title={site.title} description={site.description} path="/">
	<main id="main-content" class="main-home">
		<Hero />
		<ApproachSection />
		<TeacherSection />
		<TestimonialSection />
		<DifferenceSection />
		<ClosingSection />
	</main>

	<SiteFooter />
</BaseLayout>
