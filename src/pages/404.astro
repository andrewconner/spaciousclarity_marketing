---
import SiteFooter from '../components/SiteFooter.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
	title="Page not found | Spacious Clarity"
	description="The page you were looking for could not be found."
	path="/404"
	noindex={true}
>
	<main id="main-content">
		<section class="not-found-page">
			<div class="not-found-card">
				<span class="label">Off the map · 404</span>
				<h1>This path isn't charted yet.</h1>
				<p>
					The page you were looking for doesn't exist, or it moved while the site
					is still in its first public build.
				</p>
				<div>
					<a class="button" href="/">Return to the homepage</a>
				</div>
			</div>
		</section>
	</main>

	<SiteFooter />
</BaseLayout>
